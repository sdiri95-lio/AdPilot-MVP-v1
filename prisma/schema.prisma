datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id            String   @id @default(cuid())
  userId        String
  name          String
  productName   String
  productCost   Decimal  @db.Decimal(10, 2)
  sellingPrice  Decimal  @db.Decimal(10, 2)
  shippingCost  Decimal  @db.Decimal(10, 2)
  serviceFee    Decimal  @db.Decimal(10, 2)
  targetCountry String
  productUrl    String?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  researches    ProductResearch[]
  csvUploads    CsvUpload[]
  analyses      AdvertisingAnalysis[]
  codMetrics    CODMetrics?

  @@index([userId])
}

model ProductResearch {
  id                  String   @id @default(cuid())
  projectId           String
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  productIntelligence Json
  marketIntelligence  Json
  customerProfile     Json
  marketingArsenal    Json
  countryAnalysis     Json
  finalRecommendation Json
  
  createdAt           DateTime @default(now())

  @@index([projectId])
}

model CsvUpload {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  parsedData  Json     // Hierarchy: Campaign -> Ad Set -> Ad
  kpiSummary  Json     // Summary of spend, revenue, profit, ROAS, etc.
  
  createdAt   DateTime @default(now())

  analysis    AdvertisingAnalysis?

  @@index([projectId])
}

model AdvertisingAnalysis {
  id                  String     @id @default(cuid())
  projectId           String
  project             Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  csvUploadId         String?    @unique
  csvUpload           CsvUpload? @relation(fields: [csvUploadId], references: [id], onDelete: SetNull)

  campaignHealthScore Int
  overallDecision     String     // SCALE | OPTIMIZE | RETEST | KILL
  confidenceScore     Int

  businessIntel       Json
  creativeRanking     Json
  winningAdSets       Json
  losingAdSets        Json
  fatigueWarnings     Json
  optimizationActions Json
  actionPlan          Json
  
  createdAt           DateTime   @default(now())

  @@index([projectId])
}

model CODMetrics {
  id               String   @id @default(cuid())
  projectId        String   @unique
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  confirmationRate Decimal  @default(100) @db.Decimal(5, 2)
  deliveryRate     Decimal  @default(100) @db.Decimal(5, 2)
  returnRate       Decimal  @default(0)   @db.Decimal(5, 2)
  shippingCost     Decimal  @default(0)   @db.Decimal(10, 2)
  returnFee        Decimal  @default(0)   @db.Decimal(10, 2)
  
  createdAt        DateTime @default(now())
}
