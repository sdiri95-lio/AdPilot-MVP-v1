generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String           @id @default(cuid())
  clerkId              String           @unique
  email                String           @unique
  firstName            String?
  lastName             String?
  imageUrl             String?
  subscription         SubscriptionTier @default(FREE_TRIAL)
  stripeCustomerId     String?          @unique
  stripeSubscriptionId String?          @unique

  usage    Usage?
  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aiUsageLogs  AIUsageLog[]
  countryNotes CountryNote[]

  @@index([clerkId])
  @@index([email])
}

model Usage {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeProjectCount Int       @default(0)
  aiCallsUsed        Int       @default(0)
  aiCallsLimit       Int       @default(50)
  projectLimit       Int       @default(5)
  resetAt            DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model AIUsageLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature      String
  model        String
  tokensInput  Int
  tokensOutput Int
  totalTokens  Int
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Project {
  id     String        @id @default(cuid())
  userId String
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status ProjectStatus @default(ACTIVE)

  name          String
  productName   String
  productUrl    String?
  imageUrl      String?
  country       String?
  targetCountry String?
  productType   ProductType?
  productCost   Decimal      @db.Decimal(10, 2)
  sellingPrice  Decimal      @db.Decimal(10, 2)
  shippingCost  Decimal      @default(0) @db.Decimal(10, 2)
  serviceFee    Decimal      @default(0) @db.Decimal(10, 2)
  desiredProfit Decimal      @db.Decimal(5, 2)

  category          String?
  demand            DemandLevel?
  competition       CompetitionLevel?
  emotionalTriggers Json?
  difficultyScore   Int?
  marketOpportunity Int?

  winningProbability        Decimal?   @db.Decimal(5, 2)
  confidenceScore           Decimal?   @db.Decimal(5, 2)
  opportunityReasoning      Json?
  opportunityRecommendation String?
  analysisVersion           String     @default("v1")
  mediaBuyerReport          Json?
  riskScore                 RiskScore?
  marketScore               Int?
  productScore              Int?

  revenue           Decimal? @db.Decimal(10, 2)
  margin            Decimal? @db.Decimal(10, 2)
  marginPercent     Decimal? @db.Decimal(5, 2)
  breakEvenCpl      Decimal? @db.Decimal(10, 2)
  breakEvenCpa      Decimal? @db.Decimal(10, 2)
  targetCpl         Decimal? @db.Decimal(10, 2)
  targetCpa         Decimal? @db.Decimal(10, 2)
  minCpl            Decimal? @db.Decimal(10, 2)
  recommendedCpl    Decimal? @db.Decimal(10, 2)
  maxCpl            Decimal? @db.Decimal(10, 2)
  profitAssumptions Json?

  tests                      Test[]
  adCopies                   AdCopy[]
  csvUploads                 CsvUpload[]
  scalingLogs                ScalingLog[]
  productAnalyses            ProductAnalysis[]
  winningProbabilityAnalyses WinningProbabilityAnalysis[]
  profitAnalyses             ProfitAnalysis[]
  mediaBuyingTests           MediaBuyingTest[]
  timelineEvents             ProjectTimelineEvent[]

  productVideos   Json?
  supplierLink    String?
  weight          Decimal? @db.Decimal(10, 2)
  adLibraryLinks  Json?
  competitorLinks Json?
  notes           String?  @db.Text

  solvesProblem     Boolean @default(false)
  dailyUse          Boolean @default(false)
  easyToDemonstrate Boolean @default(false)
  viralPotential    Boolean @default(false)
  goodMargin        Boolean @default(false)
  lightweight       Boolean @default(false)
  codFriendly       Boolean @default(false)
  sustainableDemand Boolean @default(false)

  researchScore  Int?
  researchStatus ResearchStatus @default(RESEARCHING)

  importReadinessScore Int?
  supplierMoq          Int?
  supplierLeadTime     Int?      // Days
  importFreightCost    Decimal?  @db.Decimal(10, 2)

  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([productName])
  @@index([targetCountry])
  @@index([productType])
}

model Test {
  id               String        @id @default(cuid())
  projectId        String
  project          Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scenario         TestScenario
  campaignType     CampaignType
  adsetCount       Int
  budgetPerAdset   Decimal       @db.Decimal(10, 2)
  totalBudget      Decimal       @db.Decimal(10, 2)
  targetingType    TargetingType
  targetingDetails Json?
  expectedSpend    Decimal       @db.Decimal(10, 2)
  expectedLeads    Int
  expectedOrders   Int
  expectedRisk     RiskScore
  scalingLogs      ScalingLog[]
  createdAt        DateTime      @default(now())

  @@index([projectId])
}

model AdCopy {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  hooks         Json
  headlines     Json
  primaryTexts  Json
  ctaVariations Json
  marketLocale  String   @default("AFRICA_GENERAL")
  createdAt     DateTime @default(now())

  @@index([projectId])
}

model ProductAnalysis {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // AI housekeeping
  model           String
  analysisVersion String @default("v1")

  // Core AI analysis fields
  category          String?
  demand            DemandLevel?
  competition       CompetitionLevel?
  emotionalTriggers Json? // string[]
  difficultyScore   Int?
  marketOpportunity Int?
  riskScore         RiskScore?
  marketScore       Int?
  productScore      Int?

  // Sprint 3B — extended fields
  strengths              Json? // string[]
  weaknesses             Json? // string[]
  targetAudience         Json? // string[]
  pricingRecommendations Json? // string[]
  risks                  Json? // string[]

  // Full structured media buyer report
  mediaBuyerReport Json? // { summary, recommendation, strengths, weaknesses, nextActions }

  // Opportunity score inputs snapshot
  // { productScore, marketScore, riskScore, difficultyScore, marketOpportunity }
  opportunityScoreInputs Json?

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}

model WinningProbabilityAnalysis {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  model           String
  analysisVersion String @default("v1")

  winningProbability Int
  confidenceScore    Int
  reasoning          Json
  recommendation     String

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}

model ProfitAnalysis {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  model           String
  analysisVersion String @default("v1")

  revenue        Decimal @db.Decimal(10, 2)
  margin         Decimal @db.Decimal(10, 2)
  marginPercent  Decimal @db.Decimal(5, 2)
  breakEvenCpl   Decimal @db.Decimal(10, 2)
  breakEvenCpa   Decimal @db.Decimal(10, 2)
  targetCpl      Decimal @db.Decimal(10, 2)
  targetCpa      Decimal @db.Decimal(10, 2)
  minCpl         Decimal @db.Decimal(10, 2)
  recommendedCpl Decimal @db.Decimal(10, 2)
  maxCpl         Decimal @db.Decimal(10, 2)

  assumptions Json // string[]

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}

model Benchmark {
  id         String     @id @default(cuid())
  niche      String
  country    String
  metricType MetricType
  avgValue   Decimal    @db.Decimal(10, 4)
  sampleSize Int
  updatedAt  DateTime   @updatedAt

  @@unique([niche, country, metricType])
}

model CsvUpload {
  id                String           @id @default(cuid())
  projectId         String
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mediaBuyingTestId String?
  mediaBuyingTest   MediaBuyingTest? @relation(fields: [mediaBuyingTestId], references: [id], onDelete: SetNull)
  fileUrl           String
  status            CsvStatus        @default(PENDING)
  parsedData        Json?
  kpiSummary        Json?
  isWinning         Boolean?
  recommendations   Json?
  createdAt         DateTime         @default(now())

  @@index([projectId])
}

model ScalingLog {
  id             String      @id @default(cuid())
  projectId      String
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testId         String?
  test           Test?       @relation(fields: [testId], references: [id], onDelete: SetNull)
  scalingType    ScalingType
  oldBudget      Decimal?    @db.Decimal(10, 2)
  newBudget      Decimal?    @db.Decimal(10, 2)
  recommendation String      @db.Text
  appliedAt      DateTime    @default(now())

  @@index([projectId])
  @@index([testId])
}

enum SubscriptionTier {
  FREE_TRIAL
  STARTER
  PRO
  ENTERPRISE
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum ProductType {
  IMPULSE
  PROBLEM_SOLVER
  TRENDING
  UTILITY
  SEASONAL
}

enum DemandLevel {
  HIGH
  MEDIUM
  LOW
}

enum CompetitionLevel {
  HIGH
  MEDIUM
  LOW
}

enum RiskScore {
  LOW
  MEDIUM
  HIGH
}

enum TestScenario {
  MINIMUM
  BEST
  HIGH
}

enum CampaignType {
  ABO
  CBO
}

enum TargetingType {
  TARGET
  BROAD
}

enum MetricType {
  CPM
  CTR
  CPL
  CPA
  ROAS
}

enum CsvStatus {
  PENDING
  PROCESSING
  ANALYZED
  ERROR
}

enum ScalingType {
  VERTICAL
  HORIZONTAL
  BUDGET
}

enum ResearchStatus {
  RESEARCHING
  READY_FOR_TEST
  REJECTED
  WINNER
}

enum MediaBuyingTestStatus {
  RESEARCH
  READY
  PREPARING
  LAUNCHING
  TESTING
  ANALYSIS
  WINNER
  FAILED
  RETEST
}

model MediaBuyingTest {
  id          String                @id @default(cuid())
  projectId   String
  project     Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  country     String
  launchDate  DateTime?
  offer       String?
  creative    String?
  landingPage String?
  dailyBudget Decimal?              @db.Decimal(10, 2)
  status      MediaBuyingTestStatus @default(RESEARCH)

  deliveryRate     Decimal? @default(100) @db.Decimal(5, 2)
  confirmationRate Decimal? @default(100) @db.Decimal(5, 2)
  returnRate       Decimal? @default(0)   @db.Decimal(5, 2)
  shippingCost     Decimal? @default(0)   @db.Decimal(10, 2)
  returnFee        Decimal? @default(0)   @db.Decimal(10, 2)
  failureReason    String?  @db.Text

  isArchived Boolean @default(false)

  csvUploads CsvUpload[]
  creatives  CreativeTest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model CreativeTest {
  id                String          @id @default(cuid())
  mediaBuyingTestId String
  mediaBuyingTest   MediaBuyingTest @relation(fields: [mediaBuyingTestId], references: [id], onDelete: Cascade)
  
  name              String
  hook              String?
  
  spend             Decimal @default(0) @db.Decimal(10, 2)
  orders            Int     @default(0)
  revenue           Decimal @default(0) @db.Decimal(10, 2)
  ctr               Decimal @default(0) @db.Decimal(5, 2)
  cpc               Decimal @default(0) @db.Decimal(10, 2)
  cpp               Decimal @default(0) @db.Decimal(10, 2)
  roas              Decimal @default(0) @db.Decimal(10, 2)

  createdAt         DateTime @default(now())

  @@index([mediaBuyingTestId])
}

model ProjectTimelineEvent {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  eventType   String
  title       String
  description String?  @db.Text
  metadata    Json?
  
  createdAt   DateTime @default(now())

  @@index([projectId])
}

model CountryNote {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  country String
  notes   String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, country])
  @@index([userId])
}
